{
  "name": "bankhire-backend",
  "version": "1.0.0",
  "description": "Backend for BankHire banking job and referral platform",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "setup-db": "node setup-db.js",
    "setup-test-db": "node setup-test-db.js",
    "setup-db-schema": "node -e \"require('dotenv').config({path:'.env.test'}); const {sequelize} = require('./src/config/database'); sequelize.sync({force: true}).then(() => { console.log('Database schema created'); process.exit(0); }).catch(err => { console.error('Schema creation failed:', err); process.exit(1); })\"",
    "test": "cross-env NODE_ENV=test jest --runInBand --forceExit",
    "test:watch": "cross-env NODE_ENV=test jest --watch --runInBand",
    "test:coverage": "cross-env NODE_ENV=test jest --runInBand --forceExit --coverage",
    "test:auth": "cross-env NODE_ENV=test jest tests/auth.test.js --runInBand --forceExit",
    "test:roles": "cross-env NODE_ENV=test jest tests/role-access.test.js --runInBand --forceExit",
    "test:referral": "cross-env NODE_ENV=test jest tests/referral.test.js --runInBand --forceExit",
    "test:integration": "cross-env NODE_ENV=test jest tests/integration.test.js --runInBand --forceExit",
    "test:ci": "cross-env NODE_ENV=test jest --runInBand --forceExit --ci --coverage",
    "test:expiry": "node tools/testExpiryJob.js",
    "test:admin-expired": "node tools/testAdminExpiredReferrals.js",
    "test:admin-service": "node tools/testReferralAdminService.js",
    "test:e2e": "node tools/runE2E.js",
    "seed:verify": "node tools/seed_and_verify.js"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.11.0",
    "multer": "^2.0.2",
    "nodemailer": "^6.9.7",
    "pdf-parse": "^1.1.4",
    "pg": "^8.11.3",
    "sequelize": "^6.35.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@types/jest": "^30.0.0",
    "babel-jest": "^30.2.0",
    "cross-env": "^10.1.0",
    "jest": "^30.2.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.1.4"
  },
  "keywords": [
    "banking",
    "jobs",
    "referral"
  ],
  "author": "",
  "license": "ISC"
}
